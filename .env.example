# API Keys required for voice loop and LLM orchestrator
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Database Configurations
# PostgreSQL example: postgres://postgres:password@127.0.0.1:5432/voicebot
# SQLite example (default fallback): sqlite://db.sqlite3
DATABASE_URL=sqlite://db.sqlite3

# Service URLs for networking (e.g. dynamic IP addresses)
FRONTEND_URL=http://your_laptop_ip:8502
BACKEND_URL=http://your_laptop_ip:8000

