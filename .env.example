# API Keys required for voice loop and LLM orchestrator
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Database Configurations
# PostgreSQL example: postgres://postgres:password@127.0.0.1:5432/interview
# SQLite example (default fallback): sqlite://db.sqlite3
DATABASE_URL=postgres://postgres:1234@localhost:5432/interview

# Docker-specific database URL (uses internal Docker network hostname)
DATABASE_URL_DOCKER=postgres://postgres:1234@db:5432/interview

# Service URLs for networking
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# CORS Allowed Origins (comma-separated, or * for all)
# For production, set to your actual domain: https://yourdomain.com
CORS_ALLOWED_ORIGINS=*
